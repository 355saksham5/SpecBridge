{
  "name": "@specbridge/knowledge-worker",
  "version": "0.1.0",
  "private": true,
  "description": "SpecBridge knowledge bootstrap worker — stack detect, Knowledge Architect, bundle pack",
  "type": "module",
  "bin": {
    "specbridge-worker": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/index.js",
    "dev": "node --import tsx src/index.ts"
  },
  "dependencies": {
    "@azure/service-bus": "^7.9.5",
    "@specbridge/audit-log": "*",
    "@specbridge/agent-orchestrator": "*",
    "@specbridge/bundle-packer": "*",
    "@specbridge/calibration-metrics": "*",
    "@specbridge/commit-walker": "*",
    "@specbridge/confluence-client": "*",
    "@specbridge/github-client": "*",
    "@specbridge/jira-client": "*",
    "@specbridge/knowledge-store": "*",
    "@specbridge/stack-detect": "*"
  },
  "devDependencies": {
    "tsx": "^4.19.4"
  },
  "files": ["dist"]
}
